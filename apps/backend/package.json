{
  "name": "@fsm/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node -r dotenv/config dist/main.js dotenv_config_path=.env",
    "seed": "node -r dotenv/config dist/seed.js dotenv_config_path=.env",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@fsm/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@swc/core": "^1.7.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.0.0"
  }
}
